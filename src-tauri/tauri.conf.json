{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MuXolotl-Converter",
  "mainBinaryName": "MuXolotl-Converter",
  "version": "1.1.0",
  "identifier": "com.muxolotl.converter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "MuXolotl-Converter",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "center": true,
        "decorations": false,
        "transparent": false,
        "maximized": true,
        "visible": false,
        "dragDropEnabled": true,
        "useHttpsScheme": true
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "fullscreen": false,
        "resizable": false,
        "title": "MuXolotl Loading",
        "width": 600,
        "height": 400,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "shortDescription": "High-Performance Media Converter",
    "longDescription": "Professional cross-platform audio and video converter with GPU acceleration and support for 40+ formats.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}